option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: treestagram.wsgi:application

  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: staticfiles
    /assets: staticfiles/assets

container_commands:
  01_migrate:
    command: "bash -c 'source /var/app/venv/staging-*/bin/activate && python manage.py migrate'"
    leader_only: true

  02_collectstatic:
    command: "bash -c 'source /var/app/venv/staging-*/bin/activate && python manage.py collectstatic --noinput'"